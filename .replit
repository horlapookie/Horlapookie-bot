modules = ["nodejs-20", "web"]
run = "npm run start"

[nix]
channel = "stable-25_05"
packages = ["vercel-pkg"]

[deployment]
run = ["sh", "-c", "npm run start"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Start Bot"
author = 46499522
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node index.js"

[[workflows.workflow]]
name = "Web Server"
author = 47009790
mode = "sequential"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "WhatsApp Bot Web"

[[workflows.workflow]]
name = "WhatsApp Bot Web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node server.js"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 5000
externalPort = 80

[agent]
expertMode = true
